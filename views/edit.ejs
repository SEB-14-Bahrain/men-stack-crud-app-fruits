<%- include('./partials/nav') %>

    <h1>Edit <%= foundFruit.name %></h1>

    <form action="/fruits/<%= foundFruit._id %>?_method=PUT" method="POST">
        Name:
        <input type="text" name="name" value="<%= foundFruit.name %>" />

        <br />
        <div class="checkbox-div">
            Ready to Eat?
            <% if (foundFruit.isReadyToEat === true) { %>
                <input type="checkbox" name="isReadyToEat" checked />
            <% } else { %>
                <input type="checkbox" name="isReadyToEat" />
            <% } %>
        </div>

        <button type="submit">Update Fruit</button>
    </form>
</body>
</html>